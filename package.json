{
  "name": "isseo-clubpilates",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Plateforme de suivi projets Club Pilates — ISSEO",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint 'js/**/*.js'",
    "format": "prettier --write 'js/**/*.js' '*.html' '*.css' '*.json'",
    "format:check": "prettier --check 'js/**/*.js' '*.html' '*.css' '*.json'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "htm": "^3.1.1",
    "preact": "^10.29.1"
  }
}
